# GCP project that hosts Secret Manager and the GCS bucket.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS

# DEV loads secrets from this file; PROD pulls them from Secret Manager
# (IDs: {MODE}_{NAME}, e.g. PROD_MONGODB_URI). Anything set here overrides
# Secret Manager, so leave the lines below blank in PROD.
MODE=DEV

# Required secrets (leave blank in PROD to force Secret Manager lookup).
MONGODB_URI=
REDIS_URI=
GEMINI_API_KEY=
GCS_BUCKET=
